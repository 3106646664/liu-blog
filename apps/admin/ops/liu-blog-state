#!/usr/bin/env python3
import json
import os
import sys
from datetime import datetime


STATE_FILE = os.environ.get(
    "LIU_BLOG_DEPLOY_STATE", "/var/lib/liu-blog-admin/deploy-state.json"
)
BUSY = {
    "queued",
    "preparing",
    "snapshotting",
    "installing",
    "building",
    "checking",
    "switching",
}


def now():
    return datetime.now().astimezone().isoformat(timespec="seconds")


def main():
    if len(sys.argv) < 4:
        raise SystemExit("usage: liu-blog-state STATE PROGRESS MESSAGE [RELEASE]")

    state = sys.argv[1]
    progress = int(sys.argv[2])
    message = sys.argv[3]
    release = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] else None

    previous = {}
    try:
        with open(STATE_FILE, "r", encoding="utf-8") as state_file:
            previous = json.load(state_file)
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        pass

    payload = {
        "state": state,
        "message": message,
        "progress": progress,
        "busy": state in BUSY,
        "startedAt": previous.get("startedAt") or now(),
        "updatedAt": now(),
    }
    if release:
        payload["release"] = release
    elif previous.get("release"):
        payload["release"] = previous["release"]
    if state in {"success", "failed"}:
        payload["finishedAt"] = now()

    os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
    temporary = f"{STATE_FILE}.tmp"
    with open(temporary, "w", encoding="utf-8") as state_file:
        json.dump(payload, state_file, ensure_ascii=False, indent=2)
    os.replace(temporary, STATE_FILE)


if __name__ == "__main__":
    main()
