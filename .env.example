# Public Next.js server
VISIT_COUNTER_FILE=/srv/xinghui-blog/data/visits.json
XINGHUI_BLOG_ADMIN_API_URL=http://127.0.0.1:58643

# CMS backend
XINGHUI_BLOG_ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
XINGHUI_BLOG_DEPLOY_STATE=/var/lib/xinghui-blog-admin/deploy-state.json
XINGHUI_BLOG_PUBLISH_SERVICE=xinghui-blog-publish.service
XINGHUI_BLOG_MUSIC_LIBRARY=/srv/xinghui-blog-music/library.json
XINGHUI_BLOG_MUSIC_CACHE=/srv/xinghui-blog-music/cache.json
XINGHUI_BLOG_MUSIC_PAIR_STATE=/srv/xinghui-blog-music/pair-sessions.json
XINGHUI_BLOG_MUSIC_PAIR_ENDPOINT=https://admin.example.com/music-pair/complete

# Store the value in this file; never put the key itself in an environment file committed to Git.
DEEPSEEK_KEY_FILE=/srv/xinghui-blog-admin/secrets/deepseek-api-key
